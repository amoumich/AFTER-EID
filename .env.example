# Configuration de la base de données MongoDB
MONGODB_URI=mongodb://localhost:27017/after_eid

# Secret pour les sessions
SESSION_SECRET=after-eid-premium-secret-2024-changez-en-production

# Port du serveur
PORT=3000

# Environment
NODE_ENV=development

# Configuration Airtel Money (à obtenir auprès d'Airtel)
AIRTEL_MONEY_API_KEY=votre_api_key
AIRTEL_MONEY_SECRET=votre_secret_key
AIRTEL_MONEY_ENVIRONMENT=sandbox # ou production

# Configuration Email (pour les notifications)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=votre_email@gmail.com
EMAIL_PASS=votre_mot_de_passe_app

# Configuration Admin
ADMIN_PASSWORD=votre_mot_de_passe_admin_securise

# Configuration SMS (optionnel, pour les notifications SMS)
TWILIO_ACCOUNT_SID=votre_sid
TWILIO_AUTH_TOKEN=votre_token
TWILIO_PHONE_NUMBER=votre_numero_twilio

# URLs de l'application
BASE_URL=http://localhost:3000
FRONTEND_URL=http://localhost:3000

# Configuration de l'événement
EVENT_DATE=2024-03-31T18:00:00
PAYMENT_DEADLINE=2024-03-25T23:59:59

# Prix en FCFA
PAGNE_PRICE=7000
PARTICIPATION_PRICE=15000
TOTAL_PRICE=22000
